{
  "name": "endpoint_switch",
  "description": "S6.16 -- assert the chat-footer endpoint picker (locus.chat.endpoint_choice) renders, then open Settings via Ctrl+, jump to the Endpoints tab (index 1: LLM, Endpoints, Index, Agent, ...), and verify the endpoints list + Add button are addressable. Deterministic -- no live LLM needed. Selecting a dropdown row / the 'Edit endpoints...' sentinel is NOT driven here: wxChoice CBS_DROPDOWNLIST selection-by-key doesn't reliably fire wxEVT_CHOICE under UIA (see tests/ui_automation/README.md); the chip-click -> Settings path is covered by tests/manual/endpoints.md.",
  "setup": {
    "workspace": "tmp"
  },
  "steps": [
    { "op": "launch" },
    {
      "op": "wait_for_window",
      "args": { "title_prefix": "Locus", "timeout_ms": 20000 }
    },
    {
      "op": "find",
      "args": { "automation_id": "locus.chat.panel", "timeout_ms": 15000 }
    },
    { "op": "sleep", "args": { "ms": 400 } },

    {
      "op": "find",
      "args": { "automation_id": "locus.chat.endpoint_choice", "timeout_ms": 5000 }
    },
    { "op": "screenshot", "args": { "name": "01_chat_footer_endpoint_choice" } },

    {
      "op": "press_key",
      "args": { "key": "COMMA", "modifiers": "CTRL" }
    },
    {
      "op": "find",
      "args": { "automation_id": "locus.settings.notebook", "timeout_ms": 5000 }
    },
    {
      "op": "select_tab",
      "args": { "parent_aid": "locus.settings.notebook", "index": 1 }
    },
    { "op": "sleep", "args": { "ms": 400 } },
    {
      "op": "find",
      "args": { "automation_id": "locus.settings.endpoints.list", "timeout_ms": 5000 }
    },
    {
      "op": "find",
      "args": { "automation_id": "locus.settings.endpoints.add_btn", "timeout_ms": 5000 }
    },
    {
      "op": "find",
      "args": { "automation_id": "locus.settings.endpoints.set_active_btn", "timeout_ms": 5000 }
    },
    { "op": "screenshot", "args": { "name": "02_settings_endpoints_tab" } },

    { "op": "press_key", "args": { "key": "ESC" } },
    { "op": "sleep", "args": { "ms": 300 } },
    { "op": "quit", "args": { "wait_ms": 5000 } }
  ]
}
