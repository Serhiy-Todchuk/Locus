{
  "name": "help_slash",
  "description": "Submit `/help` (a built-in slash command handled directly in AgentCore::try_slash_command without an LLM round-trip) and assert the response landed in the chat WebView. Validates the deterministic slash-command path end-to-end through ChatPanel + WebView render.",
  "setup": {
    "workspace": "tmp"
  },
  "steps": [
    { "op": "launch" },
    {
      "op": "wait_for_window",
      "args": { "title_prefix": "Locus", "timeout_ms": 20000 }
    },
    {
      "op": "find",
      "args": { "automation_id": "locus.chat.panel", "timeout_ms": 15000 }
    },
    {
      "op": "click",
      "args": {
        "parent_aid": "locus.chat.panel",
        "control_type": "document",
        "timeout_ms": 10000
      }
    },
    {
      "op": "type",
      "args": {
        "parent_aid": "locus.chat.panel",
        "control_type": "document",
        "text": "/help "
      }
    },
    { "op": "sleep", "args": { "ms": 200 } },
    {
      "op": "press_key",
      "args": {
        "parent_aid": "locus.chat.panel",
        "control_type": "document",
        "key": "ENTER"
      }
    },
    {
      "op": "assert_text_contains",
      "args": {
        "automation_id": "locus.chat.webview",
        "substring": "/help",
        "walk_subtree": true,
        "timeout_ms": 10000
      }
    },
    { "op": "screenshot", "args": { "name": "01_help_response" } },
    { "op": "quit", "args": { "wait_ms": 5000 } }
  ]
}
