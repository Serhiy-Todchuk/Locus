{
  "name": "prompt_cost_and_watchdog_settings",
  "description": "Open Settings -> Tool Approvals tab and verify the S6.11/S6.12/S6.13 widgets are reachable in the UIA tree: lazy_manifest checkbox, system_prompt.profile dropdown, reasoning_max_seconds spin, reasoning_max_chars spin, reasoning_auto_nudge checkbox. Smoke-level addressability check -- exercising the actual watchdog trip requires a live LLM (covered by the manual test plan). Note: spinner / checkbox values are NOT modified here because wxChoice CBS_DROPDOWNLIST selection-by-key doesn't fire wxEVT_CHOICE reliably under UIA (see tests/ui_automation/README.md). Persistence is exercised by the existing settings_persistence script.",
  "setup": {
    "workspace": "tmp"
  },
  "steps": [
    { "op": "launch" },
    {
      "op": "wait_for_window",
      "args": { "title_prefix": "Locus", "timeout_ms": 20000 }
    },
    {
      "op": "find",
      "args": { "automation_id": "locus.chat.panel", "timeout_ms": 15000 }
    },
    { "op": "sleep", "args": { "ms": 400 } },
    { "op": "press_key", "args": { "key": "COMMA", "modifiers": "CTRL" } },
    {
      "op": "find",
      "args": { "automation_id": "locus.settings.notebook", "timeout_ms": 5000 }
    },
    {
      "op": "select_tab",
      "args": { "parent_aid": "locus.settings.notebook", "index": 3 }
    },
    { "op": "sleep", "args": { "ms": 400 } },
    { "op": "screenshot", "args": { "name": "tab_approvals_open" } },

    {
      "op": "find",
      "args": {
        "automation_id": "locus.settings.tools.lazy_manifest_cb",
        "timeout_ms": 5000
      }
    },
    {
      "op": "find",
      "args": {
        "automation_id": "locus.settings.system_prompt.profile_choice",
        "timeout_ms": 5000
      }
    },
    {
      "op": "find",
      "args": {
        "automation_id": "locus.settings.agent.reasoning_max_seconds",
        "timeout_ms": 5000
      }
    },
    {
      "op": "find",
      "args": {
        "automation_id": "locus.settings.agent.reasoning_max_chars",
        "timeout_ms": 5000
      }
    },
    {
      "op": "find",
      "args": {
        "automation_id": "locus.settings.agent.reasoning_auto_nudge_cb",
        "timeout_ms": 5000
      }
    },

    { "op": "screenshot", "args": { "name": "all_widgets_reachable" } },

    { "op": "press_key", "args": { "key": "ESC" } },
    { "op": "sleep", "args": { "ms": 300 } },
    { "op": "quit", "args": { "wait_ms": 5000 } }
  ]
}
