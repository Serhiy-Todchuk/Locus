{
  "name": "mcp_open_json",
  "description": "Settings -> MCP Servers -> Open mcp.json button. Creates a stub `.locus/mcp.json` if none exists, then hands off to the OS default app. We assert the file got created and screenshot before/after; we deliberately don't reach into the default-app launch since that's out of scope for UIA (and may pop a Notepad window that lingers after the script).",
  "setup": {
    "workspace": "tmp"
  },
  "steps": [
    { "op": "launch" },
    {
      "op": "wait_for_window",
      "args": { "title_prefix": "Locus", "timeout_ms": 20000 }
    },
    {
      "op": "find",
      "args": { "automation_id": "locus.chat.panel", "timeout_ms": 15000 }
    },
    { "op": "sleep", "args": { "ms": 400 } },
    { "op": "press_key", "args": { "key": "COMMA", "modifiers": "CTRL" } },
    {
      "op": "find",
      "args": { "automation_id": "locus.settings.notebook", "timeout_ms": 5000 }
    },
    {
      "op": "select_tab",
      "args": { "parent_aid": "locus.settings.notebook", "index": 6 }
    },
    { "op": "sleep", "args": { "ms": 400 } },
    { "op": "screenshot", "args": { "name": "01_mcp_tab" } },

    {
      "op": "click",
      "args": { "automation_id": "locus.settings.mcp.open_json_btn", "timeout_ms": 5000 }
    },
    { "op": "sleep", "args": { "ms": 600 } },
    {
      "op": "assert_file_exists",
      "args": { "path": ".locus/mcp.json", "timeout_ms": 5000 }
    },
    { "op": "screenshot", "args": { "name": "02_after_open_json" } },

    { "op": "press_key", "args": { "key": "ESC" } },
    { "op": "sleep", "args": { "ms": 300 } },
    { "op": "quit", "args": { "wait_ms": 5000 } }
  ]
}
