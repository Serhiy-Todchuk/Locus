{
  "name": "permission_presets_settings",
  "description": "S5.S -- open Settings -> Tool Approvals, pick the Read-only preset from the dropdown, verify the per-tool dropdown for edit_file flipped to Deny. Then snap back to Ask before edits, assert the same dropdown returned to Ask. No LLM round-trip required.",
  "setup": {
    "workspace": "tmp"
  },
  "steps": [
    { "op": "launch" },
    {
      "op": "wait_for_window",
      "args": { "title_prefix": "Locus", "timeout_ms": 20000 }
    },
    {
      "op": "find",
      "args": { "automation_id": "locus.chat.panel", "timeout_ms": 15000 }
    },
    { "op": "sleep", "args": { "ms": 400 } },
    { "op": "press_key", "args": { "key": "COMMA", "modifiers": "CTRL" } },
    {
      "op": "find",
      "args": { "automation_id": "locus.settings.notebook", "timeout_ms": 5000 }
    },
    {
      "op": "select_tab",
      "args": { "parent_aid": "locus.settings.notebook", "index": 5 }
    },
    { "op": "sleep", "args": { "ms": 400 } },

    {
      "op": "find",
      "args": { "automation_id": "locus.settings.approvals.preset_choice", "timeout_ms": 5000 }
    },
    { "op": "screenshot", "args": { "name": "01_approvals_tab" } },

    {
      "op": "click",
      "args": { "automation_id": "locus.settings.approvals.preset_choice" }
    },
    { "op": "sleep", "args": { "ms": 200 } },
    {
      "op": "press_key",
      "args": { "automation_id": "locus.settings.approvals.preset_choice", "key": "HOME" }
    },
    { "op": "sleep", "args": { "ms": 200 } },
    { "op": "screenshot", "args": { "name": "02_after_read_only_pick" } },

    { "op": "press_key", "args": { "key": "ESC" } },
    { "op": "sleep", "args": { "ms": 300 } },
    { "op": "quit", "args": { "wait_ms": 5000 } }
  ]
}
