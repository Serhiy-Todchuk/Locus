{
  "name": "save_as_global_defaults",
  "description": "S5.M -- click the `Save as global defaults` button on the Settings dialog and verify that ~/.locus/config.json (overridden via the test-only LOCUS_GLOBAL_DIR env var) gets written. The dialog pops a confirmation message box first; we accept it with Enter.",
  "setup": {
    "workspace": "tmp",
    "env": {
      "LOCUS_GLOBAL_DIR": "{workspace}/global"
    }
  },
  "steps": [
    { "op": "launch" },
    {
      "op": "wait_for_window",
      "args": { "title_prefix": "Locus", "timeout_ms": 20000 }
    },
    {
      "op": "find",
      "args": { "automation_id": "locus.chat.panel", "timeout_ms": 15000 }
    },
    { "op": "sleep", "args": { "ms": 400 } },
    { "op": "press_key", "args": { "key": "COMMA", "modifiers": "CTRL" } },
    {
      "op": "find",
      "args": { "automation_id": "locus.settings.notebook", "timeout_ms": 5000 }
    },
    {
      "op": "click",
      "args": { "automation_id": "locus.settings.save_as_global_btn", "timeout_ms": 5000 }
    },
    { "op": "sleep", "args": { "ms": 400 } },
    { "op": "press_key", "args": { "key": "ENTER" } },
    { "op": "sleep", "args": { "ms": 400 } },
    { "op": "press_key", "args": { "key": "ENTER" } },
    { "op": "sleep", "args": { "ms": 300 } },
    {
      "op": "assert_file_exists",
      "args": { "path": "global/config.json", "timeout_ms": 5000 }
    },
    { "op": "screenshot", "args": { "name": "01_saved" } },

    { "op": "press_key", "args": { "key": "ESC" } },
    { "op": "sleep", "args": { "ms": 300 } },
    { "op": "quit", "args": { "wait_ms": 5000 } }
  ]
}
