{
  "name": "tool_approval_dialog",
  "description": "End-to-end approval gate. Forces write_file back to `ask` via setup.tool_approvals_override (which the harness merges into the tmp workspace's `.locus/config.json` pre-seed), then prompts the LLM to write a file. Expected: ToolApprovalDialog opens, the script clicks Approve, the file lands on disk. Requires LM Studio at http://127.0.0.1:1234 with a tool-calling model -- on flakes, see .locus/locus.log for dropped-tool-call warnings (the model, not the harness).",
  "setup": {
    "workspace": "tmp",
    "tool_approvals_override": {
      "write_file": "ask"
    }
  },
  "steps": [
    { "op": "launch" },
    {
      "op": "wait_for_window",
      "args": { "title_prefix": "Locus", "timeout_ms": 30000 }
    },
    {
      "op": "find",
      "args": { "automation_id": "locus.chat.panel", "timeout_ms": 30000 }
    },

    {
      "op": "click",
      "args": { "parent_aid": "locus.chat.panel", "control_type": "document" }
    },
    {
      "op": "type",
      "args": {
        "parent_aid": "locus.chat.panel",
        "control_type": "document",
        "text": "Use the write_file tool to create a file named approved.txt containing the words 'tool approval works'. Just write the file -- do not run it."
      }
    },
    { "op": "sleep", "args": { "ms": 300 } },
    {
      "op": "press_key",
      "args": {
        "parent_aid": "locus.chat.panel",
        "control_type": "document",
        "key": "ENTER"
      }
    },

    {
      "op": "wait_for_window",
      "args": { "title_prefix": "Tool Approval", "timeout_ms": 240000 }
    },
    {
      "op": "find",
      "args": { "automation_id": "locus.tool_approval.dialog", "timeout_ms": 5000 }
    },
    {
      "op": "find",
      "args": { "automation_id": "locus.tool_approval.approve_btn", "timeout_ms": 5000 }
    },
    { "op": "screenshot", "args": { "name": "01_approval_dialog" } },

    {
      "op": "click",
      "args": { "automation_id": "locus.tool_approval.approve_btn", "timeout_ms": 5000 }
    },
    { "op": "sleep", "args": { "ms": 1000 } },

    {
      "op": "assert_file_exists",
      "args": { "path": "approved.txt", "timeout_ms": 60000 }
    },
    { "op": "screenshot", "args": { "name": "02_file_written" } },

    { "op": "quit", "args": { "wait_ms": 5000 } }
  ]
}
