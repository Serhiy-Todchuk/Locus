{
  "name": "terminal_panel_run",
  "description": "S5.B terminal panel populated by a real run_command call. With run_command pre-seeded to auto-approve, prompts the LLM to echo a known string. The terminal panel auto-shows on first run; the script then asserts the panel becomes visible and the chat WebView eventually contains the echoed string (the chat-side tool-result bubble carries the same output). Requires LM Studio at http://127.0.0.1:1234 with a tool-calling model.",
  "setup": {
    "workspace": "tmp"
  },
  "steps": [
    { "op": "launch" },
    {
      "op": "wait_for_window",
      "args": { "title_prefix": "Locus", "timeout_ms": 30000 }
    },
    {
      "op": "find",
      "args": { "automation_id": "locus.chat.panel", "timeout_ms": 30000 }
    },

    {
      "op": "click",
      "args": { "parent_aid": "locus.chat.panel", "control_type": "document" }
    },
    {
      "op": "type",
      "args": {
        "parent_aid": "locus.chat.panel",
        "control_type": "document",
        "text": "Use the run_command tool to run the single command: echo hello-from-terminal-panel"
      }
    },
    { "op": "sleep", "args": { "ms": 300 } },
    {
      "op": "press_key",
      "args": {
        "parent_aid": "locus.chat.panel",
        "control_type": "document",
        "key": "ENTER"
      }
    },

    {
      "op": "assert_text_contains",
      "args": {
        "automation_id": "locus.chat.webview",
        "substring": "hello-from-terminal-panel",
        "walk_subtree": true,
        "timeout_ms": 240000
      }
    },
    { "op": "screenshot", "args": { "name": "01_chat_shows_output" } },

    { "op": "press_key", "args": { "key": "BACKTICK", "modifiers": "CTRL" } },
    { "op": "sleep", "args": { "ms": 600 } },
    {
      "op": "find",
      "args": { "automation_id": "locus.terminal.panel", "timeout_ms": 5000 }
    },
    {
      "op": "assert_visible",
      "args": { "automation_id": "locus.terminal.panel", "timeout_ms": 5000 }
    },
    { "op": "screenshot", "args": { "name": "02_terminal_visible" } },

    { "op": "quit", "args": { "wait_ms": 5000 } }
  ]
}
