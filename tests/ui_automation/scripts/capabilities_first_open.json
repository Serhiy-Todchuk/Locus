{
  "name": "capabilities_first_open",
  "description": "S5.A first-open Capabilities modal -- opt out of the harness's default `--no-first-time-prompts` injection so LocusApp shows the dialog on a fresh tmp workspace. The script verifies the dialog appears, that the five named checkboxes exist, toggles `Web retrieval` on (default off), OKs, then relaunches the same workspace to confirm the choice persisted (Capabilities tab in Settings should show Web checked).",
  "setup": {
    "workspace": "tmp",
    "allow_first_time_prompts": true
  },
  "steps": [
    { "op": "launch" },
    {
      "op": "wait_for_window",
      "args": { "title_prefix": "Workspace Capabilities", "timeout_ms": 20000 }
    },
    { "op": "sleep", "args": { "ms": 600 } },
    {
      "op": "find",
      "args": { "automation_id": "locus.capabilities.cb_web", "timeout_ms": 20000 }
    },
    { "op": "screenshot", "args": { "name": "01_first_open_modal" } },

    { "op": "find", "args": { "automation_id": "locus.capabilities.cb_background" } },
    { "op": "find", "args": { "automation_id": "locus.capabilities.cb_semantic" } },
    { "op": "find", "args": { "automation_id": "locus.capabilities.cb_code" } },
    { "op": "find", "args": { "automation_id": "locus.capabilities.cb_memory" } },
    { "op": "find", "args": { "automation_id": "locus.capabilities.cb_web" } },

    {
      "op": "click",
      "args": { "automation_id": "locus.capabilities.cb_web", "timeout_ms": 5000 }
    },
    { "op": "sleep", "args": { "ms": 300 } },
    { "op": "screenshot", "args": { "name": "02_web_toggled_on" } },

    { "op": "press_key", "args": { "key": "ENTER" } },
    { "op": "sleep", "args": { "ms": 800 } },
    {
      "op": "wait_for_window",
      "args": { "title_prefix": "Locus", "timeout_ms": 15000 }
    },

    {
      "op": "find",
      "args": { "automation_id": "locus.chat.panel", "timeout_ms": 15000 }
    },
    { "op": "screenshot", "args": { "name": "03_main_window_loaded" } },
    { "op": "quit", "args": { "wait_ms": 8000 } },

    { "op": "sleep", "args": { "ms": 1500 } },

    { "op": "launch" },
    {
      "op": "wait_for_window",
      "args": { "title_prefix": "Locus", "timeout_ms": 20000 }
    },
    {
      "op": "find",
      "args": { "automation_id": "locus.chat.panel", "timeout_ms": 15000 }
    },
    { "op": "sleep", "args": { "ms": 400 } },
    { "op": "press_key", "args": { "key": "COMMA", "modifiers": "CTRL" } },
    {
      "op": "find",
      "args": { "automation_id": "locus.settings.notebook", "timeout_ms": 5000 }
    },
    {
      "op": "select_tab",
      "args": { "parent_aid": "locus.settings.notebook", "index": 2 }
    },
    { "op": "sleep", "args": { "ms": 400 } },
    { "op": "screenshot", "args": { "name": "04_capabilities_tab" } },

    { "op": "press_key", "args": { "key": "ESC" } },
    { "op": "sleep", "args": { "ms": 300 } },
    { "op": "quit", "args": { "wait_ms": 5000 } }
  ]
}
