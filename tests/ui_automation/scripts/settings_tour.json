{
  "name": "settings_tour",
  "description": "Open the Settings dialog via Ctrl+, click through several tabs by index, screenshot each, then close. Also asserts the S6.14 Thinking ON/OFF/auto dropdown is reachable on the LLM tab. Tabs are addressed by index because wxNotebook on Windows wraps SysTabControl32, which doesn't propagate labels to UIA Name (see tests/ui_automation/README.md). Page order: LLM(0), Endpoints(1), Index(2), Agent(3), Capabilities(4), Tool Approvals(5), MCP(6), Security(7), Web(8), Notifications(9), Sessions(10). Actually toggling the Thinking dropdown + asserting config.json persistence is deferred to tests/manual/llm-settings.md because wxChoice selection-by-key is unreliable under UIA (README caveat).",
  "setup": {
    "workspace": "tmp"
  },
  "steps": [
    { "op": "launch" },
    {
      "op": "wait_for_window",
      "args": { "title_prefix": "Locus", "timeout_ms": 20000 }
    },
    {
      "op": "find",
      "args": { "automation_id": "locus.chat.panel", "timeout_ms": 15000 }
    },
    { "op": "sleep", "args": { "ms": 500 } },
    {
      "op": "press_key",
      "args": { "key": "COMMA", "modifiers": "CTRL" }
    },
    {
      "op": "find",
      "args": { "automation_id": "locus.settings.notebook", "timeout_ms": 5000 }
    },
    { "op": "screenshot", "args": { "name": "settings_open" } },

    {
      "op": "select_tab",
      "args": { "parent_aid": "locus.settings.notebook", "index": 0 }
    },
    { "op": "sleep", "args": { "ms": 300 } },
    {
      "op": "find",
      "args": { "automation_id": "locus.settings.llm.thinking_mode", "timeout_ms": 5000 }
    },
    {
      "op": "assert_visible",
      "args": { "automation_id": "locus.settings.llm.thinking_mode" }
    },
    { "op": "screenshot", "args": { "name": "tab_llm" } },

    {
      "op": "select_tab",
      "args": { "parent_aid": "locus.settings.notebook", "index": 2 }
    },
    { "op": "sleep", "args": { "ms": 300 } },
    { "op": "screenshot", "args": { "name": "tab_index" } },

    {
      "op": "select_tab",
      "args": { "parent_aid": "locus.settings.notebook", "index": 4 }
    },
    { "op": "sleep", "args": { "ms": 300 } },
    { "op": "screenshot", "args": { "name": "tab_capabilities" } },

    {
      "op": "select_tab",
      "args": { "parent_aid": "locus.settings.notebook", "index": 5 }
    },
    { "op": "sleep", "args": { "ms": 300 } },
    { "op": "screenshot", "args": { "name": "tab_approvals" } },

    {
      "op": "select_tab",
      "args": { "parent_aid": "locus.settings.notebook", "index": 6 }
    },
    { "op": "sleep", "args": { "ms": 300 } },
    { "op": "screenshot", "args": { "name": "tab_mcp" } },

    { "op": "press_key", "args": { "key": "ESC" } },
    { "op": "sleep", "args": { "ms": 300 } },
    { "op": "quit", "args": { "wait_ms": 5000 } }
  ]
}
