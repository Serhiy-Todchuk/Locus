{
  "name": "tabs_new_and_close",
  "description": "S5.I -- exercise the multi-tab notebook on the center pane. Verifies the wxAuiNotebook is reachable as `locus.chat.notebook`, opens a new tab via the Ctrl+T accelerator, screenshots the two-tab state, then closes the active tab via Ctrl+W and verifies the notebook is still present (the last-tab-close should auto-open a fresh empty tab in its place, never leaving the workspace tab-less). Pure shell test -- no LLM involvement.",
  "setup": {
    "workspace": "tmp"
  },
  "steps": [
    { "op": "launch" },
    {
      "op": "wait_for_window",
      "args": { "title_prefix": "Locus", "timeout_ms": 20000 }
    },
    {
      "op": "find",
      "args": { "automation_id": "locus.chat.panel", "timeout_ms": 15000 }
    },
    {
      "op": "find",
      "args": { "automation_id": "locus.chat.notebook", "timeout_ms": 5000 }
    },
    { "op": "screenshot", "args": { "name": "01_single_tab" } },

    { "op": "press_key", "args": { "key": "T", "modifiers": "CTRL" } },
    { "op": "sleep", "args": { "ms": 500 } },
    {
      "op": "assert_visible",
      "args": { "automation_id": "locus.chat.notebook", "timeout_ms": 5000 }
    },
    { "op": "screenshot", "args": { "name": "02_after_ctrl_t" } },

    { "op": "press_key", "args": { "key": "W", "modifiers": "CTRL" } },
    { "op": "sleep", "args": { "ms": 500 } },
    {
      "op": "find",
      "args": { "automation_id": "locus.chat.notebook", "timeout_ms": 5000 }
    },
    { "op": "screenshot", "args": { "name": "03_after_ctrl_w" } },

    { "op": "quit", "args": { "wait_ms": 5000 } }
  ]
}
